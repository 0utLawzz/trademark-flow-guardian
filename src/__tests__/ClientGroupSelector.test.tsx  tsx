import { render, screen, waitFor } from '@testing-library/react';
import { BrowserRouter } from 'react-router-dom';
import ClientGroupSelector from '../components/ClientGroupSelector';
import { supabase } from '../lib/supabaseClient';

jest.mock('../lib/supabaseClient');

const mocked = supabase as jest.Mocked<typeof supabase>;

test('renders client groups', async () => {
  mocked.from.mockReturnValueOnce({
    select: jest.fn().mockResolvedValue({
      data: [
        { id: '1111-aaaa', name: 'X A & N' },
        { id: '2222-bbbb', name: 'Y B & O' },
      ],
      error: null,
    }),
  } as any);

  render(
    <BrowserRouter>
      <ClientGroupSelector />
    </BrowserRouter>
  );

  await waitFor(() => {
    expect(screen.getByText('X A & N')).toBeInTheDocument();
    expect(screen.getByText('Y B & O')).toBeInTheDocument();
  });
});
